<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="category.products.list">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">MageJ_QuickView::product/list.phtml</argument>
            </action>
            <arguments>
                <argument name="quickViewViewModel" xsi:type="object">MageJ\QuickView\ViewModel\QuickViewConfig</argument>
            </arguments>
        </referenceBlock>

        <referenceContainer name="before.body.end">
            <block name="iflw.quickview.init" template="MageJ_QuickView::init.phtml"/>
        </referenceContainer>
    </body>
</page>

