
<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                brandcarousel_brand_form.brandcarousel_brand_form_data_source
            </item>
            <item name="deps" xsi:type="string">
                brandcarousel_brand_form.brandcarousel_brand_form_data_source
            </item>
        </item>
        <item name="label" xsi:type="string" translate="true">
            General Information
        </item>
        <item name="template" xsi:type="string">
            templates/form/collapsible
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="back" class="MageJ\BrandCarousel\Block\Adminhtml\Index\Edit\BackButton"/>
            <button name="delete" class="MageJ\BrandCarousel\Block\Adminhtml\Index\Edit\DeleteButton"/>
            <button name="reset" class="MageJ\BrandCarousel\Block\Adminhtml\Index\Edit\ResetButton"/>
            <button name="save" class="MageJ\BrandCarousel\Block\Adminhtml\Index\Edit\SaveButton"/>
            <button name="save_and_continue" class="MageJ\BrandCarousel\Block\Adminhtml\Index\Edit\SaveAndContinueButton"/>
        </buttons>
        <namespace>brandcarousel_brand_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>brandcarousel_brand_form.brandcarousel_brand_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="brandcarousel_brand_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>                
        <aclResource>MageJ_BrandCarousel::brand_brands</aclResource>
        <dataProvider class="MageJ\BrandCarousel\Model\Brand\DataProvider" name="brandcarousel_brand_form_data_source">
            <settings>
                <requestFieldName>brand_id</requestFieldName>
                <primaryFieldName>brand_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">Brand Slider Information</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="brand_id" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">brand</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>brand_id</dataScope>
            </settings>
        </field>
        <field name="status" sortOrder="10" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">brand</item>
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Enable Brand</label>
                <dataScope>status</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">2</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="name" sortOrder="20" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">brand</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Brand Title</label>
                <dataScope>name</dataScope>
            </settings>
        </field>
        <field name="logo" sortOrder="40" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">brand</item>
                </item>
            </argument>
            <settings>
                <elementTmpl>ui/form/element/uploader/image</elementTmpl>
                <dataType>string</dataType>
                <label translate="true">Brand Logo</label>
                <visible>true</visible>
                <required>true</required>
                <dataScope>logo</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="brandcarousel/index_image/upload"/>
                            <param name="fileParameter" xsi:type="string">logo</param>
                        </uploaderConfig>
                        <previewTmpl>MageJ_BrandCarousel/image-preview</previewTmpl>
                        <openDialogTitle>Media Gallery</openDialogTitle>
                        <initialMediaGalleryOpenSubpath>MageJ/brand</initialMediaGalleryOpenSubpath>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>4194304</maxFileSize>
                    </settings>
                </imageUploader>
            </formElements>
        </field>    
        <field name="logo_alt" sortOrder="41" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">brand</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Brand Logo Alt Text</label>
                <dataScope>logo_alt</dataScope>
            </settings>
        </field>
        <field name="sort_order" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">brand</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Sort order</label>
                <dataScope>sort_order</dataScope>
            </settings>
        </field>
        <field name="storeviews" formElement="multiselect" class="Magento\Store\Ui\Component\Form\Field\StoreView">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">brand</item>
                    <item name="default" xsi:type="number">0</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>int</dataType>
                <tooltip>
                    <link>https://docs.magento.com/user-guide/configuration/scope.html</link>
                    <description>What is this?</description>
                </tooltip>
                <label translate="true">Store View</label>
                <dataScope>store_id</dataScope>
            </settings>
            <formElements>
                <multiselect>
                    <settings>
                        <options class="MageJ\BrandCarousel\Ui\Component\Listing\Column\StoreView"/>
                    </settings>
                </multiselect>
            </formElements>
        </field>
    </fieldset>
</form>
