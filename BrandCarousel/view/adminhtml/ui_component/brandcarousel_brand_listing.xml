
<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">brandcarousel_brand_listing.brandcarousel_brand_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/add"/>
                <class>primary</class>
                <label translate="true">Add New Brand</label>
            </button>
        </buttons>
        <spinner>brandcarousel_brand_columns</spinner>
        <deps>
            <dep>brandcarousel_brand_listing.brandcarousel_brand_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="brandcarousel_brand_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">brand_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>MageJ_BrandCarousel::brand_brands</aclResource>
        <dataProvider class="MageJ\BrandCarousel\Ui\Component\DataProvider" name="brandcarousel_brand_listing_data_source">
            <settings>
                <requestFieldName>brand_id</requestFieldName>
                <primaryFieldName>brand_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <massaction name="listing_massaction" component="Magento_Ui/js/grid/tree-massactions">
            <action name="delete">
                <settings>
                   <confirm>
                        <message translate="true">Delete selected items?</message>
                        <title translate="true">Delete items</title>
                    </confirm>
                    <url path="brandcarousel/index/massdelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>            
            </action>
            <action name="change_status">
                <settings>
                    <confirm>
                        <message translate="true">Change status to 'Disable' selected items?</message>
                        <title translate="true">Change status</title>
                    </confirm>
                    <type>change_status</type>
                    <label translate="true">Disable</label>
                    <url path="brandcarousel/index/massstatus"/>
                </settings>
            </action>
        </massaction>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="brandcarousel_brand_columns">
        <settings>
            <editorConfig>
                <param name="clientConfig" xsi:type="array">
                    <item name="saveUrl" xsi:type="url" path="brandcarousel/index/inlineEdit"/>
                    <item name="validateBeforeSave" xsi:type="boolean">false</item>
                </param>
                <param name="indexField" xsi:type="string">brand_id</param>
                <param name="enabled" xsi:type="boolean">true</param>
                <param name="selectProvider" xsi:type="string">brandcarousel_brand_listing.brandcarousel_brand_listing.brandcarousel_brand_columns.ids</param>
            </editorConfig>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">brandcarousel_brand_listing.brandcarousel_brand_listing.brandcarousel_brand_columns_editor</item>
                    <item name="target" xsi:type="string">startEdit</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                        <item name="1" xsi:type="boolean">true</item>
                    </item>
                </param>
            </childDefaults>
        </settings>
        <selectionsColumn name="ids" sortOrder="10">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="resizeEnabled" xsi:type="boolean">false</item>
                    <item name="resizeDefaultWidth" xsi:type="string">55</item>
                    <item name="indexField" xsi:type="string">brand_id</item>
                </item>                    
            </argument>
        </selectionsColumn>
         <column name="sr_no">
            <settings>
                <label translate="true">SR No.</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="store_id" class="Magento\Store\Ui\Component\Listing\Column\Store">
            <settings>
                <label translate="true">Store View</label>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <sorting>asc</sorting>
                <editor>
                    <validation>
                        <rule name="required-entry" xsi:type="boolean">true</rule>
                    </validation>
                    <editorType>text</editorType>
                </editor>
                <label translate="true">Brand Name</label>
            </settings>
        </column>
        <column name="logo_alt">
            <settings>
                <filter>text</filter>
                <editor>
                    <validation>
                        <rule name="required-entry" xsi:type="boolean">true</rule>
                    </validation>
                    <editorType>text</editorType>
                </editor>
                <label translate="true">Logo Alt Text</label>
            </settings>
        </column>
        <column name="status" class="MageJ\BrandCarousel\Ui\Component\Listing\Column\Status">
            <settings>
                <options class="Magento\Cms\Model\Page\Source\IsActive"/>
                <filter>select</filter>
                <editor>
                    <editorType>select</editorType>
                </editor>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="sort_order">
            <settings>
                <filter>textRange</filter>
                <sorting>asc</sorting>
                <editor>
                    <validation>
                        <rule name="required-entry" xsi:type="boolean">true</rule>
                        <rule name="validate-number" xsi:type="boolean">true</rule>
                        <rule name="greater-than-equals-to" xsi:type="number">0</rule>
                    </validation>
                    <editorType>text</editorType>
                </editor>
                <label translate="true">Sort Order</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="MageJ\BrandCarousel\Ui\Component\Listing\Column\BrandActions">
            <settings>
                <indexField>brand_id</indexField>
            </settings>
        </actionsColumn>           
    </columns>
</listing>
